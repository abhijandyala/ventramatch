# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz

# Build / cache (root-anchored so app/build/ etc. aren't ignored)
.next/
/out/
/build/
/dist/
*.tsbuildinfo
.turbo/

# Environment
.env
.env.local
.env.*.local
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Testing / coverage
coverage/
.nyc_output/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
*.pem

# Media at repo root — assets must live under /public/media/, never the root.
# Keeps large recordings from being tracked accidentally.
/*.mov
/*.MOV
/*.mp4
/*.MP4
/*.webm
/*.WEBM
/*.png
/*.PNG
/*.jpg
/*.JPG
/*.jpeg
/*.JPEG
/*.gif
/*.GIF

# Vercel
.vercel

# Generated types (regenerate via npm run db:types if needed)
# Keep types/database.ts checked in for diff visibility

# Synthetic matching pipeline — generated output, not source data
# Regenerate with: npm run generate:synthetic-matches
data/synthetic-matching/pairs.json

# Synthetic matching ML artifacts — generated by scripts/ml/train_synthetic_matching.py
# Regenerate with: npm run train:synthetic-matches
data/synthetic-matching/artifacts/*
!data/synthetic-matching/artifacts/.gitkeep

# Synthetic matching embeddings — generated by scripts/ml/compute_embeddings.py
# Regenerate with: npm run embeddings:synthetic-matches
data/synthetic-matching/embeddings/*
!data/synthetic-matching/embeddings/.gitkeep

# Python ML tooling (scripts/ml/)
scripts/ml/.venv/
scripts/ml/__pycache__/
scripts/ml/*.pyc
__pycache__/
*.pyc

# Local skill caches
.cursor/skills/**/__pycache__/
.cursor/skills/**/*.pyc

# npx skills add — duplicates .cursor/skills; do not commit
.agents/
skills-lock.json
