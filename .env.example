# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------- App ----------
# Public site URL. Used for auth redirects and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ---------- Database (Railway Postgres) ----------
# Full connection string. Locally: postgres://postgres:postgres@localhost:5432/ventramatch
# Railway: copy from project → Postgres → Variables → DATABASE_URL.
DATABASE_URL=

# Read-only / pooled URL (optional, used by edge runtime if/when we add it).
# DATABASE_URL_POOLED=

# ---------- File storage (AWS S3) ----------
# Bucket region (e.g. us-east-1) and bucket name.
AWS_REGION=us-east-1
AWS_S3_BUCKET=ventramatch-uploads

# Credentials. In production these come from IAM role / Railway env, not from .env.local.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: a CloudFront / public CDN domain in front of the bucket.
# AWS_S3_PUBLIC_URL=https://cdn.ventramatch.com

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM="VentraMatch <hello@ventramatch.com>"

# ---------- AI (post-MVP) ----------
# OPENAI_API_KEY=

# ---------- Payments (post-MVP) ----------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
