# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------- PostgreSQL (Railway or local) ----------
# Connection string. Server-only; never expose to the browser.
# On Railway, the TCP proxy host (e.g. *.proxy.rlwy.net) works from your laptop; *.railway.internal only works inside Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# Optional: duplicate of the public proxy URL if you keep both names in tooling.
# DATABASE_PUBLIC_URL=

# ---------- App ----------
# Public site URL. Used for auth redirects and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Auth.js (NextAuth v5) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional in dev; required in prod when not on Vercel. On Railway, set this.
AUTH_URL=http://localhost:3000
# Required when running behind a proxy (e.g. Railway). Set to "true".
AUTH_TRUST_HOST=true

# ---------- OAuth: Google ----------
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- OAuth: LinkedIn ----------
# https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product (NOT legacy OAuth 2.0).
# Redirect URL: http://localhost:3000/api/auth/callback/linkedin
# Scopes: openid profile email
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# ---------- OAuth: Microsoft Entra ID ----------
# https://entra.microsoft.com/ → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Issuer: single-tenant uses /<tenant-id>/v2.0; multi-tenant uses /common/v2.0
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM="VentraMatch <hello@ventramatch.com>"

# ---------- AI (post-MVP) ----------
# OPENAI_API_KEY=

# ---------- Payments (post-MVP) ----------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
