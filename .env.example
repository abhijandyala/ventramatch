# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------- PostgreSQL (Railway or local) ----------
# Connection string. Server-only; never expose to the browser.
# On Railway, the TCP proxy host (e.g. *.proxy.rlwy.net) works from your laptop; *.railway.internal only works inside Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# Optional: duplicate of the public proxy URL if you keep both names in tooling.
# DATABASE_PUBLIC_URL=

# ---------- App ----------
# Public site URL. Used for auth redirects and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Auth.js (NextAuth v5) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional in dev; required in prod when not on Vercel. On Railway, set this.
AUTH_URL=http://localhost:3000
# Required when running behind a proxy (e.g. Railway). Set to "true".
AUTH_TRUST_HOST=true

# ---------- OAuth: Google ----------
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- OAuth: LinkedIn ----------
# https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product (NOT legacy OAuth 2.0).
# Redirect URL: http://localhost:3000/api/auth/callback/linkedin
# Scopes: openid profile email
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# ---------- OAuth: Microsoft Entra ID ----------
# https://entra.microsoft.com/ → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Issuer: single-tenant uses /<tenant-id>/v2.0; multi-tenant uses /common/v2.0
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM="VentraMatch <hello@ventramatch.com>"

# ---------- File storage (AWS S3) ----------
# Used by /api/deck/upload to store founder pitch decks (Sprint 9.5.B).
# Bucket should be PRIVATE — reads are gated by /api/deck/[startupId]
# which verifies the viewer has match-unlocked the founder, then issues
# a presigned download URL with a 1h TTL. Never make the bucket public.
#
# Setup checklist (see docs/workflow.md → File storage):
#   1. Create an S3 bucket (any region; us-east-1 is the default).
#   2. Block ALL public access in the bucket settings.
#   3. Create an IAM user with a policy granting:
#      s3:PutObject, s3:GetObject, s3:DeleteObject, s3:HeadObject
#      on arn:aws:s3:::<bucket>/decks/*
#   4. Generate an access key for that user and put the values below.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ventramatch-uploads-prod

# ---------- Error tracking (Sentry) ----------
# Create a project at https://sentry.io → Settings → Projects → Create.
# The DSN is on the project's "Client Keys" page.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional: source map uploads (get from Settings → Auth Tokens)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ---------- Cache (Upstash Redis) ----------
# Free tier: https://console.upstash.com → Create Database → REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- AI (post-MVP) ----------
# OPENAI_API_KEY=

# ---------- Payments (post-MVP) ----------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
