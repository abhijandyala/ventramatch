# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------- Supabase ----------
# Project URL (e.g. https://abcd1234.supabase.co) — public, safe in NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — public, used by browser client. Safe to ship; RLS enforces security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- App ----------
# Public site URL. Used for auth redirects and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM="VentraMatch <hello@ventramatch.com>"

# ---------- AI (post-MVP) ----------
# OPENAI_API_KEY=

# ---------- Payments (post-MVP) ----------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
