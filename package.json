{
  "name": "ventramatch",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered matching platform for startups and investors.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "echo 'Apply db/migrations/*.sql to DATABASE_URL (e.g. psql)'",
    "db:apply": "node scripts/apply-migration.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "analyze:synthetic-matches": "python3 scripts/ml/analyze_semantic_agreement.py",
    "embeddings:synthetic-matches": "python3 scripts/ml/compute_embeddings.py",
    "generate:synthetic-matches": "tsx scripts/generate-synthetic-match-pairs.ts",
    "train:synthetic-matches": "python3 scripts/ml/train_synthetic_matching.py",
    "eval-ranking:synthetic-matches": "python3 scripts/ml/eval_ranking.py",
    "eval-ranking-oof:synthetic-matches": "python3 scripts/ml/eval_ranking.py --source oof",
    "train-multiseed:synthetic-matches": "python3 scripts/ml/train_synthetic_matching.py --multiseed",
    "eval-ranking-multiseed:synthetic-matches": "python3 scripts/ml/eval_ranking.py --source multiseed",
    "eval-calibration:synthetic-matches": "python3 scripts/ml/eval_calibration.py",
    "simulate-personas:synthetic-matches": "python3 scripts/ml/personalization/generate_personas.py && python3 scripts/ml/personalization/simulate_actions.py && python3 scripts/ml/personalization/preference_vector.py",
    "evaluate-personalization:synthetic-matches": "python3 scripts/ml/personalization/personalize.py && python3 scripts/ml/personalization/eval_personalization.py",
    "prepare-personalization:synthetic-matches": "npm run simulate-personas:synthetic-matches && npm run evaluate-personalization:synthetic-matches",
    "quality:synthetic-matches": "tsx scripts/quality/run_quality_review.ts",
    "prepare:synthetic-matches": "npm run embeddings:synthetic-matches && npm run generate:synthetic-matches && npm run train:synthetic-matches",
    "export-coefficients": "python3 scripts/ml/export_coefficients.py",
    "validate-model:production": "tsx scripts/ml/validate_production_features.ts",
    "validate-ranker:production": "tsx scripts/ml/validate_ml_ranker.ts",
    "validate-personalization:production": "tsx scripts/ml/validate_personalization_runtime.ts",
    "validate-quality:production": "tsx scripts/ml/validate_quality_runtime.ts",
    "validate-impressions:production": "tsx scripts/ml/validate_impression_log.ts",
    "validate-integration:production": "tsx scripts/ml/validate_integration.ts",
    "validate:all": "tsx scripts/validate_all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@sentry/nextjs": "^10.51.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "3.0.3",
    "clsx": "2.1.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lottie-react": "^2.4.1",
    "lucide-react": "0.545.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "ogl": "^1.0.11",
    "postgres": "3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.7",
    "resend": "^6.12.2",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.16",
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.16",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
