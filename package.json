{
  "name": "ventramatch",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered matching platform for startups and investors.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
