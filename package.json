    "lucide-react": "0.545.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "typescript": "5.9.3",
    "tailwindcss": "4.1.16",
    "@tailwindcss/postcss": "4.1.16",
    "postcss": "8.5.6",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.0",
    "eslint-config-next": "^16.2.4",
    "prettier": "3.6.2"
